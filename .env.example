# ── Choix du fournisseur LLM ──────────────────────────────────────────────
# Fournisseurs disponibles (voir llm.py) :
#   openrouter | anthropic | openai | github_copilot | custom
# Par défaut (LLM_PROVIDER non défini) : auto-détection du 1er fournisseur dont
# la clé est présente (openrouter si OPENROUTER_API_KEY, sinon anthropic…).
# Forçage explicite :
# LLM_PROVIDER=openrouter

# === OpenRouter (par défaut, recommandé : compte avec crédits) ===
# Clé API OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=
# Modèle FORT en tool calling (~61 outils exposés). Liste complète : https://openrouter.ai/models
# Recommandés (ids vérifiés, tous compatibles tool calling) :
#   Performants : deepseek/deepseek-v4-pro, anthropic/claude-opus-4.8, openai/gpt-5.5, openai/gpt-5.5-pro, x-ai/grok-4.3, qwen/qwen3.7-max
#   Rapides     : deepseek/deepseek-v4-flash, openai/gpt-5.4-mini, google/gemini-3.5-flash, anthropic/claude-opus-4.8-fast, qwen/qwen3.7-plus
OPENROUTER_MODEL=deepseek/deepseek-v4-pro
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# === Anthropic (API native) ===
# ANTHROPIC_API_KEY=
# Modèle Claude. Défaut : claude-sonnet-4-6 ; complexe : claude-opus-4-8
# LLM_MODEL=claude-opus-4-8

# === OpenAI (API native) ===
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.openai.com/v1

# === GitHub Copilot (via le proxy local copilot-api, cf. README) ===
# LLM_PROVIDER=github_copilot
# COPILOT_BASE_URL=http://localhost:4141/v1
# COPILOT_API_KEY=copilot
# COPILOT_MODEL=gpt-4o

# === Custom : tout endpoint compatible OpenAI (opencode, vLLM, Ollama, …) ===
# Permet d'ajouter un fournisseur SANS toucher au code.
# LLM_PROVIDER=custom
# LLM_BASE_URL=http://localhost:8080/v1
# LLM_API_KEY=none
# LLM_MODEL_NAME=mon-modele
